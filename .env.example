# Openapi.it — Catasto / Territorio
# Bearer token for the catasto v3 API. Required.
OPENAPI_TOKEN=

# Base URL for the catasto provider. Optional.
# Production: https://catasto.openapi.it
# Sandbox:    https://test.catasto.openapi.it
# If unset, the server falls back to the sandbox URL and logs a warning.
OPENAPI_CATASTO_BASE_URL=
